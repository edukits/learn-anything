{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://learn-anything.local/content-schemas/v1/quiz-question.schema.json",
	"title": "Quiz question",
	"type": "object",
	"required": [
		"id",
		"version",
		"topic_area_id",
		"skill_id",
		"device",
		"question_purpose",
		"response_type",
		"difficulty",
		"prompt",
		"explanation",
		"content_run_id",
		"schema_version",
		"source_refs"
	],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"version": { "type": "integer", "minimum": 1 },
		"topic_area_id": { "type": "string", "minLength": 1 },
		"skill_id": { "type": "string", "minLength": 1 },
		"device": { "type": "string", "minLength": 1 },
		"question_purpose": {
			"enum": ["recognition", "application"]
		},
		"response_type": {
			"enum": ["multiple_choice", "multiple_select", "numeric", "sequencing", "short_answer"]
		},
		"difficulty": { "enum": ["easy", "medium", "hard"] },
		"prompt": { "type": "string", "minLength": 1 },
		"choices": {
			"type": "array",
			"minItems": 2,
			"items": {
				"type": "object",
				"required": ["id", "label"],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"label": { "type": "string", "minLength": 1 }
				},
				"additionalProperties": false
			}
		},
		"correct_choice_id": { "type": "string", "minLength": 1 },
		"correct_choice_ids": {
			"type": "array",
			"minItems": 2,
			"items": { "type": "string", "minLength": 1 }
		},
		"correct_numeric_answer": {
			"type": "object",
			"additionalProperties": false,
			"required": ["value"],
			"properties": {
				"value": { "type": "number" },
				"tolerance": { "type": "number", "minimum": 0 }
			}
		},
		"sequence_items": {
			"type": "array",
			"minItems": 2,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "label"],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"label": { "type": "string", "minLength": 1 }
				}
			}
		},
		"accepted_answers": {
			"type": "array",
			"minItems": 1,
			"items": { "type": "string", "minLength": 1 }
		},
		"grading_rubric": {
			"type": "string",
			"minLength": 1,
			"description": "Reviewer-facing guidance only. Launch-critical grading still requires accepted_answers."
		},
		"explanation": { "type": "string", "minLength": 1 },
		"content_run_id": { "type": "string", "minLength": 1 },
		"schema_version": { "type": "integer", "minimum": 1 },
		"source_refs": {
			"type": "array",
			"items": { "$ref": "subject-area.schema.json#/$defs/source_ref" }
		}
	},
	"allOf": [
		{
			"if": { "properties": { "response_type": { "const": "short_answer" } } },
			"then": { "required": ["accepted_answers"] }
		}
	],
	"additionalProperties": false
}
