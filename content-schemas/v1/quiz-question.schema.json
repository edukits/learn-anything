{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://clarifyst.local/content-schemas/v1/quiz-question.schema.json",
	"title": "Quiz question",
	"type": "object",
	"required": [
		"id",
		"version",
		"topic_area_id",
		"skill_id",
		"device",
		"question_purpose",
		"response_type",
		"difficulty",
		"prompt",
		"explanation",
		"content_run_id",
		"schema_version",
		"source_refs"
	],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"version": { "type": "integer", "minimum": 1 },
		"topic_area_id": { "type": "string", "minLength": 1 },
		"skill_id": { "type": "string", "minLength": 1 },
		"device": { "type": "string", "minLength": 1 },
		"question_purpose": {
			"enum": ["recognition", "application"]
		},
		"response_type": {
			"enum": [
				"multiple_choice",
				"multiple_select",
				"numeric",
				"sequencing",
				"short_answer",
				"math",
				"image_choice"
			]
		},
		"difficulty": { "enum": ["easy", "medium", "hard"] },
		"prompt": {
			"type": "string",
			"minLength": 1,
			"description": "Learner-facing prompt rendered as Markdown. Supports LaTeX math."
		},
		"choices": {
			"type": "array",
			"minItems": 2,
			"items": {
				"type": "object",
				"required": ["id"],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"label": {
						"type": "string",
						"minLength": 1,
						"description": "Choice text rendered as Markdown. Supports LaTeX math."
					},
					"image_src": { "type": "string", "minLength": 1 },
					"image_alt": { "type": "string", "minLength": 1 }
				},
				"additionalProperties": false
			}
		},
		"choice_order_strategy": {
			"enum": ["shuffle", "fixed"],
			"default": "shuffle",
			"description": "Controls learner-facing choice ordering. Use shuffle by default; use fixed only when the authored order is meaningful."
		},
		"fixed_choice_ids": {
			"type": "array",
			"default": [],
			"uniqueItems": true,
			"description": "Choice ids that must remain in their authored positions while other choices are shuffled.",
			"items": { "type": "string", "minLength": 1 }
		},
		"correct_choice_id": { "type": "string", "minLength": 1 },
		"correct_choice_ids": {
			"type": "array",
			"minItems": 2,
			"items": { "type": "string", "minLength": 1 }
		},
		"correct_numeric_answer": {
			"type": "object",
			"additionalProperties": false,
			"required": ["value"],
			"properties": {
				"value": { "type": "number" },
				"tolerance": { "type": "number", "minimum": 0 }
			}
		},
		"sequence_items": {
			"type": "array",
			"minItems": 2,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "label"],
				"properties": {
					"id": { "type": "string", "minLength": 1 },
					"label": {
						"type": "string",
						"minLength": 1,
						"description": "Sequencing item text rendered as Markdown. Supports LaTeX math."
					}
				}
			}
		},
		"accepted_answers": {
			"type": "array",
			"minItems": 1,
			"items": { "type": "string", "minLength": 1 }
		},
		"math_template": {
			"type": "string",
			"minLength": 1,
			"description": "Optional MathLive LaTeX template for math response prompts."
		},
		"math_match_mode": {
			"enum": ["exact", "normalized"],
			"default": "normalized"
		},
		"accepted_math_answers": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"properties": {
					"latex": { "type": "string", "minLength": 1 },
					"prompts": {
						"type": "object",
						"minProperties": 1,
						"additionalProperties": { "type": "string", "minLength": 1 }
					},
					"matchMode": { "enum": ["exact", "normalized"] },
					"feedback": {
						"type": "string",
						"minLength": 1,
						"description": "Optional answer-specific feedback rendered as Markdown."
					}
				},
				"anyOf": [
					{ "required": ["latex"] },
					{
						"required": ["prompts"],
						"properties": {
							"prompts": {
								"type": "object",
								"minProperties": 1,
								"additionalProperties": { "type": "string", "minLength": 1 }
							}
						}
					}
				]
			}
		},
		"grading_rubric": {
			"type": "string",
			"minLength": 1,
			"description": "Reviewer-facing guidance only. Launch-critical grading still requires accepted_answers."
		},
		"explanation": {
			"type": "string",
			"minLength": 1,
			"description": "Answer explanation rendered as sanitized Markdown after submission. Supports LaTeX math; raw HTML is not part of the authoring contract."
		},
		"content_run_id": { "type": "string", "minLength": 1 },
		"schema_version": { "type": "integer", "minimum": 1 },
		"source_refs": {
			"type": "array",
			"items": { "$ref": "subject-area.schema.json#/$defs/source_ref" }
		}
	},
	"allOf": [
		{
			"if": { "properties": { "response_type": { "const": "multiple_choice" } } },
			"then": {
				"required": ["choices", "correct_choice_id"],
				"properties": {
					"choices": {
						"items": { "required": ["id", "label"] }
					}
				}
			}
		},
		{
			"if": { "properties": { "response_type": { "const": "multiple_select" } } },
			"then": {
				"required": ["choices", "correct_choice_ids"],
				"properties": {
					"choices": {
						"items": { "required": ["id", "label"] }
					}
				}
			}
		},
		{
			"if": { "properties": { "response_type": { "const": "numeric" } } },
			"then": { "required": ["correct_numeric_answer"] }
		},
		{
			"if": { "properties": { "response_type": { "const": "sequencing" } } },
			"then": { "required": ["sequence_items"] }
		},
		{
			"if": { "properties": { "response_type": { "const": "short_answer" } } },
			"then": { "required": ["accepted_answers"] }
		},
		{
			"if": { "properties": { "response_type": { "const": "math" } } },
			"then": { "required": ["accepted_math_answers"] }
		},
		{
			"if": { "properties": { "response_type": { "const": "image_choice" } } },
			"then": {
				"required": ["choices", "correct_choice_id"],
				"properties": {
					"choices": {
						"items": { "required": ["id", "image_src", "image_alt"] }
					}
				}
			}
		}
	],
	"additionalProperties": false
}
