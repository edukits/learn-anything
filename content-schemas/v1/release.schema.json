{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://clarifyst.local/content-schemas/v1/release.schema.json",
	"title": "Content release",
	"type": "object",
	"required": ["id", "slug", "title", "scope_type", "scope_id", "status", "content_run_id", "bundle_key", "items", "manifest"],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"slug": { "type": "string", "minLength": 1 },
		"title": { "type": "string", "minLength": 1 },
		"scope_type": { "enum": ["subject_area", "topic_area", "learning_path", "content_bundle"] },
		"scope_id": { "type": "string", "minLength": 1 },
		"status": { "enum": ["draft", "published", "retired"] },
		"published_at": { "type": ["string", "null"], "format": "date-time" },
		"content_run_id": { "type": "string", "minLength": 1 },
		"bundle_key": { "type": "string", "minLength": 1 },
		"items": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["content_type", "content_id", "content_version"],
				"properties": {
					"content_type": { "enum": ["subject_area", "topic_area", "skill", "lesson", "quiz", "quiz_question", "learning_path", "media_asset"] },
					"content_id": { "type": "string", "minLength": 1 },
					"content_version": { "type": "integer", "minimum": 1 }
				},
				"additionalProperties": false
			}
		},
		"manifest": { "type": "object" }
	},
	"additionalProperties": false
}
