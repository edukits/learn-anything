{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://clarifyst.local/content-schemas/v1/learning-path.schema.json",
	"title": "Learning path",
	"type": "object",
	"required": ["id", "version", "topic_area_id", "slug", "title", "summary", "items", "content_run_id", "schema_version", "source_refs"],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"version": { "type": "integer", "minimum": 1 },
		"topic_area_id": { "type": "string", "minLength": 1 },
		"slug": { "type": "string", "minLength": 1 },
		"title": { "type": "string", "minLength": 1 },
		"summary": { "type": "string", "minLength": 1 },
		"items": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["item_type", "item_id", "item_version", "ordering", "required"],
				"properties": {
					"item_type": { "enum": ["lesson", "quiz"] },
					"item_id": { "type": "string", "minLength": 1 },
					"item_version": { "type": "integer", "minimum": 1 },
					"ordering": { "type": "integer", "minimum": 1 },
					"required": { "type": "boolean" }
				},
				"additionalProperties": false
			}
		},
		"content_run_id": { "type": "string", "minLength": 1 },
		"schema_version": { "type": "integer", "minimum": 1 },
		"source_refs": { "type": "array", "items": { "$ref": "subject-area.schema.json#/$defs/source_ref" } }
	},
	"additionalProperties": false
}
