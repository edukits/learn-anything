{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://clarifyst.local/content-schemas/v1/subject-area.schema.json",
	"title": "Subject area",
	"type": "object",
	"required": ["id", "version", "slug", "name", "summary", "content_run_id", "schema_version", "source_refs"],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"version": { "type": "integer", "minimum": 1 },
		"slug": { "type": "string", "minLength": 1 },
		"name": { "type": "string", "minLength": 1 },
		"summary": { "type": "string", "minLength": 1 },
		"content_run_id": { "type": "string", "minLength": 1 },
		"schema_version": { "type": "integer", "minimum": 1 },
		"source_refs": { "type": "array", "items": { "$ref": "#/$defs/source_ref" } }
	},
	"additionalProperties": false,
	"$defs": {
		"source_ref": {
			"type": "object",
			"required": ["source_id"],
			"properties": { "source_id": { "type": "string", "minLength": 1 } },
			"additionalProperties": true
		}
	}
}
