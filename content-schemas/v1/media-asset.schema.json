{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://clarifyst.local/content-schemas/v1/media-asset.schema.json",
	"title": "Media asset",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"version",
		"asset_type",
		"storage_bucket",
		"storage_path",
		"mime_type",
		"content_run_id",
		"schema_version",
		"source_refs"
	],
	"properties": {
		"id": { "type": "string", "minLength": 1 },
		"version": { "type": "integer", "minimum": 1 },
		"asset_type": { "enum": ["image", "audio", "video", "document", "interactive"] },
		"storage_bucket": { "type": "string", "minLength": 1 },
		"storage_path": { "type": "string", "minLength": 1 },
		"mime_type": { "type": "string", "minLength": 1 },
		"alt_text": { "type": ["string", "null"], "minLength": 1 },
		"content_run_id": { "type": "string", "minLength": 1 },
		"schema_version": { "type": "integer", "minimum": 1 },
		"source_refs": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["source_id"],
				"properties": {
					"source_id": { "type": "string", "minLength": 1 },
					"path": { "type": "string", "minLength": 1 },
					"metadata_path": { "type": "string", "minLength": 1 }
				}
			}
		}
	}
}
