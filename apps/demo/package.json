		"vite": "^8.0.13"
	},
	"devDependencies": {
		"@learn-anything/config": "workspace:*",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.1",
		"oxlint": "^1.66.0",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3"
