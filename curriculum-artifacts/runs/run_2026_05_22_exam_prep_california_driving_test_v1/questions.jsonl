{"id":"question_ca_signs_stop_1","version":1,"content_run_id":"run_2026_05_22_exam_prep_california_driving_test_v1","schema_version":1,"source_refs":[{"source_id":"source_exam_prep_california_driving_test_v1","path":"content-sources/exam-prep/california-driving-test/source.md","metadata_path":"content-sources/exam-prep/california-driving-test/metadata.json"}],"topic_area_id":"topic_california_driving_test","skill_id":"skill_ca_signs_signals","device":"Signs and Signals","difficulty":"easy","prompt":"What must you do at a stop sign?","choices":[{"id":"a","label":"Slow only if another vehicle is present."},{"id":"b","label":"Make a full stop before proceeding when safe."},{"id":"c","label":"Tap the brakes and continue."},{"id":"d","label":"Stop only if turning left."}],"correct_choice_id":"b","explanation":"A stop sign requires a full stop before entering or crossing when it is safe.","question_purpose":"recognition","response_type":"multiple_choice"}
